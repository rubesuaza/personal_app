@page "/book-detail/{bookId:int}"


@if (Book == null)
{
    <p>Cargando...</p>
}
else
{
    <div class="container mt-4">
        <div class="card shadow-lg p-4">
            <div class="row">
                <div class="col-md-4 d-flex flex-column align-items-center">
                    @if (Book != null && !string.IsNullOrEmpty(Book.ImagePath))
                    {
                        <img src="@Book.ImagePath"
                             alt="Portada del libro"
                             class="img-fluid rounded"
                             style="max-width: 300px; height: auto;" />
                    }
                    else
                    {
                        <p>No hay imagen disponible.</p>
                    }
               
                    <!-- Botón debajo de la imagen -->
                    @if (Book != null)
                    {
                        <button class="btn btn-primary btn-sm mt-3"
                                style="width: auto;"
                                @onclick="() => OpenImageModal()">
                            <i class="fas fa-edit"></i> @((Book?.ImagePath != null) ? "Cambiar Imagen" : "Agregar Imagen")
                        </button>
                    }
                </div>
                



                <div class="col-md-8">
                    <h2 class="fw-bold">@Book.Title</h2>
                    <h5 class="text-muted">Autor: @Book.Author</h5>


                    <div class="mt-3">                      
                    <span class="badge badge-pill @GetRatingClass(@Book.Raiting)">Calificación:@Book.Raiting / 10</span>
                        <button class="btn btn-primary btn-sm me-2" @onclick="() => OpenRaitingModal()">
                            <i class="fas fa-edit"></i>
                            @(Book.Raiting == 0 ? "Agregar Calificación" : "Modificar Calificación")
                        </button>                                               
                    </div>
                    <hr class="my-4">
                    <div class="p-4 m-4">
                        <p class="mt-3"><strong>Descripción:</strong> @Book.Description</p>
                        <button class="btn btn-primary btn-sm me-2" @onclick="() => OpenDescriptionModal()">
                            <i class="fas fa-edit"></i>
                            @(String.IsNullOrEmpty(Book.Description) ? "Agregar Descripción" : "Modificar Descripción")
                        </button>
                    </div>
                    <hr class="my-4">




                    <div class="p-4 m-4">
                        <p><strong>Opinión personal:</strong> @Book.PersonalReview</p>
                        <button class="btn btn-primary btn-sm me-2" @onclick="() => OpenPersonalReviwModal()">
                            <i class="fas fa-edit"></i>
                            @(String.IsNullOrEmpty(Book.PersonalReview) ? "Agregar Opinión" : "Modificar Opinión")
                        </button>
                    </div>


                    <hr class="my-4">

                    <p class="fw-bold text-primary">Costo: @Book.Price.ToString("C")</p>
                </div>
            </div>
            <div class="mt-4 text-center">
                <!-- Botón para descargar PDF -->
                <button class="btn btn-success btn-sm me-2" @onclick="DownloadPdf">
                    <i class="fas fa-file-pdf"></i> Descargar PDF
                </button>

                <!-- Botón para volver -->
                <button class="btn btn-secondary btn-sm" @onclick="GoBack">
                    <i class="fas fa-arrow-left"></i> Volver
                </button>
            </div>
        </div>
        <AddImageComponent ShowModal="showImageModal" Book="Book" OnClose="CloseImageModal" OnSave="SaveBookChanges" />
        <AddDescriptionComponent ShowModal="showDescriptionModal" Book="Book"  OnClose="CloseDescriptionModal" OnSave="SaveBookChanges"/>
        <AddPersonalReviewComponent ShowModal="showPersonalReviewModal" Book="Book" OnClose="ClosePersonalReviewModal" OnSave="SaveBookChanges" />
        <AddRaitingComponent ShowModal="showRaitingModal" Book="Book" OnClose="CloseRaitingModal" OnSave="SaveBookChanges" />
    </div>
}


